{
  "schema_version": "0.1.0",
  "capsule_id": "ergaxiom.profession.graphic-designer",
  "version": "0.3.0",
  "profession": {
    "name": "graphic_designer",
    "display_name": "Graphic Designer",
    "description": "Produces digital and print-ready visual artifacts under explicit technical, brand and delivery constraints.",
    "specializations": [
      "social_media_design",
      "brand_compliance",
      "image_editing",
      "print_preflight",
      "vector_artwork"
    ]
  },
  "standards": [
    {
      "id": "wcag-contrast",
      "name": "WCAG text contrast requirements",
      "version": "2.2",
      "required_for": [
        "social_media_static_post"
      ],
      "reference": null
    },
    {
      "id": "icc-color-management",
      "name": "ICC color profile handling",
      "version": "capsule-defined",
      "required_for": [
        "social_media_static_post"
      ],
      "reference": null
    }
  ],
  "job_types": [
    {
      "id": "social_media_static_post",
      "description": "Create one static social-media artwork from approved brand assets and supplied copy.",
      "specialization": "social_media_design",
      "required_inputs": [
        "approved_logo",
        "brand_profile",
        "approved_copy"
      ],
      "required_outputs": [
        "editable_master",
        "delivery_raster",
        "evidence_bundle"
      ],
      "required_constraints": [
        "canvas_width",
        "canvas_height",
        "color_profile",
        "logo_aspect_ratio",
        "logo_clear_space",
        "text_within_safe_area",
        "minimum_text_contrast",
        "export_media_type"
      ],
      "operator_ids": [
        "design.create_canvas",
        "design.place_asset",
        "design.compose_text",
        "design.export_raster",
        "inkscape.canvas.resize",
        "inkscape.layer.create",
        "inkscape.asset.place",
        "inkscape.text.create",
        "inkscape.color.set_fill",
        "inkscape.object.transform",
        "inkscape.object.align",
        "inkscape.object.distribute",
        "inkscape.document.save_svg",
        "inkscape.export.profiled"
      ],
      "minimum_assurance_level": "E3"
    }
  ],
  "operators": [
    {
      "id": "design.create_canvas",
      "version": "0.1.0",
      "description": "Create a new document with an explicit canvas, unit and color profile.",
      "input_types": [
        "canvas_specification"
      ],
      "output_types": [
        "editable_document"
      ],
      "preconditions": [
        "canvas_dimensions_are_positive",
        "color_profile_is_supported"
      ],
      "postconditions": [
        "document_exists",
        "document_dimensions_match_contract",
        "document_color_profile_matches_contract"
      ],
      "permissions": [
        "application.control:design_editor",
        "filesystem.write:workspace"
      ],
      "execution_methods": [
        "document_model",
        "application_api",
        "signed_plugin"
      ],
      "deterministic": true,
      "randomness_seed_required": false,
      "rollback": {
        "supported": true,
        "strategy": "discard isolated document"
      }
    },
    {
      "id": "design.place_asset",
      "version": "0.1.0",
      "description": "Place an immutable approved asset while preserving declared geometric invariants.",
      "input_types": [
        "editable_document",
        "approved_asset",
        "placement_specification"
      ],
      "output_types": [
        "editable_document"
      ],
      "preconditions": [
        "asset_hash_matches_contract",
        "asset_is_decodable",
        "placement_is_within_canvas"
      ],
      "postconditions": [
        "asset_layer_exists",
        "asset_aspect_ratio_is_preserved",
        "asset_clear_space_is_satisfied"
      ],
      "permissions": [
        "filesystem.read:contract_inputs",
        "application.control:design_editor"
      ],
      "execution_methods": [
        "document_model",
        "application_api",
        "signed_plugin"
      ],
      "deterministic": true,
      "randomness_seed_required": false,
      "rollback": {
        "supported": true,
        "strategy": "remove inserted layer"
      }
    },
    {
      "id": "design.compose_text",
      "version": "0.1.0",
      "description": "Create text layers from approved copy and explicit typography constraints.",
      "input_types": [
        "editable_document",
        "approved_copy",
        "typography_specification"
      ],
      "output_types": [
        "editable_document"
      ],
      "preconditions": [
        "copy_is_approved",
        "font_is_available_and_permitted",
        "safe_area_is_defined"
      ],
      "postconditions": [
        "text_matches_approved_copy",
        "text_is_inside_safe_area",
        "text_has_no_overflow"
