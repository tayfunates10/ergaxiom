{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ergaxiom.dev/schemas/windows-bridge-request.schema.json",
  "title": "Ergaxiom Windows Bridge Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "request_id", "bridge_id", "plan_id", "plan_digest",
    "step_id", "operator_id", "executor_id", "device_id", "control_method",
    "application", "selector", "action", "required_grant",
    "expected_pre_state_digest", "postconditions", "authorization_receipt_digest"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "request_id": {"type": "string", "minLength": 1},
    "bridge_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "step_id": {"type": "string", "minLength": 1},
    "operator_id": {"type": "string", "minLength": 1},
    "executor_id": {"type": "string", "minLength": 1},
    "device_id": {"type": ["string", "null"]},
    "control_method": {
      "enum": [
        "NATIVE_MODEL", "APPLICATION_API", "SIGNED_PLUGIN", "CLI",
        "UI_AUTOMATION", "ACCESSIBILITY", "VISUALLY_CONFIRMED", "COORDINATE_FALLBACK"
      ]
    },
    "application": {"$ref": "#/$defs/applicationIdentity"},
    "selector": {"$ref": "#/$defs/selector"},
    "action": {"$ref": "#/$defs/action"},
    "required_grant": {"$ref": "authorization-receipt.schema.json#/$defs/grant"},
    "expected_pre_state_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "postconditions": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/assertion"}
    },
    "authorization_receipt_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "applicationIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["application_id", "version", "executable_digest", "instance_id"],
      "properties": {
        "application_id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "executable_digest": {"type": "string", "minLength": 1},
        "instance_id": {"type": "string", "minLength": 1}
      }
    },
    "selector": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "object_id"],
          "properties": {"selector": {"const": "NATIVE_OBJECT"}, "object_id": {"type": "string", "minLength": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "object_id"],
          "properties": {"selector": {"const": "APPLICATION_OBJECT"}, "object_id": {"type": "string", "minLength": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "plugin_id", "object_id"],
          "properties": {
            "selector": {"const": "PLUGIN_OBJECT"},
            "plugin_id": {"type": "string", "minLength": 1},
            "object_id": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "executable_id"],
          "properties": {"selector": {"const": "CLI_ENDPOINT"}, "executable_id": {"type": "string", "minLength": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "automation_id", "control_type"],
          "properties": {
            "selector": {"const": "UI_AUTOMATION"},
            "automation_id": {"type": "string", "minLength": 1},
            "control_type": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "role", "name"],
          "properties": {
            "selector": {"const": "ACCESSIBILITY"},
            "role": {"type": "string", "minLength": 1},
            "name": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "region_id"],
          "properties": {"selector": {"const": "VISUAL_REGION"}, "region_id": {"type": "string", "minLength": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["selector", "x", "y", "confirmation_region_id"],
          "properties": {
            "selector": {"const": "COORDINATES"},
            "x": {"type": "integer"},
            "y": {"type": "integer"},
            "confirmation_region_id": {"type": "string", "minLength": 1}
          }
        }
      ]
    },
    "action": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["action", "value"],
          "properties": {"action": {"const": "SET_VALUE"}, "value": {"type": "string"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["action"],
          "properties": {"action": {"const": "INVOKE"}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["action", "option_id"],
          "properties": {"action": {"const": "SELECT"}, "option_id": {"type": "string", "minLength": 1}}
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["action", "destination_artifact_id", "media_type"],
          "properties": {
            "action": {"const": "EXPORT"},
            "destination_artifact_id": {"type": "string", "minLength": 1},
            "media_type": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["action", "executable_digest", "arguments"],
          "properties": {
            "action": {"const": "RUN_CLI"},
            "executable_digest": {"type": "string", "minLength": 1},
            "arguments": {"type": "array", "items": {"type": "string"}}
          }
        }
      ]
    },
    "assertion": {
      "oneOf": [
        {
          "type": "object", "additionalProperties": false,
          "required": ["assertion", "key", "value"],
          "properties": {
            "assertion": {"const": "PROPERTY_EQUALS"},
            "key": {"type": "string", "minLength": 1},
            "value": {"type": "string"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["assertion", "artifact_id", "digest"],
          "properties": {
            "assertion": {"const": "ARTIFACT_DIGEST_EQUALS"},
            "artifact_id": {"type": "string", "minLength": 1},
            "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
          }
        },
        {
          "type": "object", "additionalProperties": false,
          "required": ["assertion", "stable_id"],
          "properties": {
            "assertion": {"const": "TARGET_STABLE_ID_EQUALS"},
            "stable_id": {"type": "string", "minLength": 1}
          }
        }
      ]
    }
  }
}
