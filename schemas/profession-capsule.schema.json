{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ergaxiom.dev/schemas/profession-capsule.schema.json",
  "title": "Ergaxiom Profession Capsule",
  "description": "A versioned package of professional capabilities, rules, validators and policies.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capsule_id",
    "version",
    "profession",
    "job_types",
    "operators",
    "validators",
    "policies"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "capsule_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "profession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "display_name", "description"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "display_name": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "specializations": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "standards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "version", "required_for"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "version": {"type": "string"},
          "required_for": {
            "type": "array",
            "items": {"type": "string"}
          },
          "reference": {"type": ["string", "null"]}
        }
      }
    },
    "job_types": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/jobType"}
    },
    "operators": {
      "type": "array",
      "items": {"$ref": "#/$defs/operator"}
    },
    "validators": {
      "type": "array",
      "items": {"$ref": "#/$defs/validator"}
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_network", "unknown_handling", "self_verification_allowed"],
      "properties": {
        "default_network": {
          "enum": ["denied", "allowlisted", "unrestricted"]
        },
        "unknown_handling": {
          "enum": ["stop", "request_resolution", "allow_optional_only"]
        },
        "self_verification_allowed": {"const": false},
        "irreversible_actions_require_approval": {"type": "boolean"},
        "minimum_assurance_by_job_type": {
          "type": "object",
          "additionalProperties": {
            "enum": ["E0", "E1", "E2", "E3", "E4", "E5"]
          }
        }
      }
    },
    "training": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "live_learning_allowed": {"const": false},
        "certification_suite": {"type": ["string", "null"]},
        "minimum_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "required_zero_failure_tests": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "jobType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "required_inputs", "required_outputs", "required_constraints", "operator_ids"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "specialization": {"type": ["string", "null"]},
        "required_inputs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_outputs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "required_constraints": {
          "type": "array",
          "items": {"type": "string"}
        },
        "operator_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "minimum_assurance_level": {
          "enum": ["E0", "E1", "E2", "E3", "E4", "E5"]
        }
      }
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "description",
        "input_types",
        "output_types",
        "preconditions",
        "postconditions",
        "permissions",
        "execution_methods",
        "rollback"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "description": {"type": "string", "minLength": 1},
        "input_types": {
          "type": "array",
          "items": {"type": "string"}
        },
        "output_types": {
          "type": "array",
          "items": {"type": "string"}
        },
        "preconditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "postconditions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "permissions": {
          "type": "array",
          "items": {"type": "string"}
        },
        "execution_methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "document_model",
              "application_api",
              "signed_plugin",
              "cli",
              "os_automation",
              "accessibility",
              "visual_confirmed",
              "coordinate_constrained"
            ]
          }
        },
        "deterministic": {"type": "boolean"},
        "randomness_seed_required": {"type": "boolean"},
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": ["supported", "strategy"],
          "properties": {
            "supported": {"type": "boolean"},
            "strategy": {"type": "string"}
          }
        }
      }
    },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "claims", "independence_class", "evidence_types", "deterministic"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "version": {"type": "string", "minLength": 1},
        "claims": {
          "type": "array",
          "items": {"type": "string"}
        },
        "independence_class": {
          "enum": ["executor", "independent", "diverse"]
        },
        "evidence_types": {
          "type": "array",
          "items": {"type": "string"}
        },
        "deterministic": {"type": "boolean"},
        "implementation": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
