{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ergaxiom.dev/schemas/authorized-execution-trace.schema.json",
  "title": "Ergaxiom Authorized Execution Trace",
  "description": "An operator-plan execution trace whose events are bound to independently issued authorization receipts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "trace_id",
    "plan_id",
    "plan_digest",
    "claimed_conforms_to_authorized_plan",
    "authorization_receipts",
    "events"
  ],
  "properties": {
    "schema_version": {"const": "0.1.0"},
    "trace_id": {"type": "string", "minLength": 1},
    "plan_id": {"type": "string", "minLength": 1},
    "plan_digest": {"type": "string", "minLength": 1},
    "claimed_conforms_to_authorized_plan": {"type": "boolean"},
    "authorization_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/authorizationReceiptRecord"}
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/receiptBoundTraceEvent"}
    }
  },
  "$defs": {
    "authorizationReceiptRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receipt_digest", "receipt"],
      "properties": {
        "receipt_digest": {"type": "string", "minLength": 1},
        "receipt": {"$ref": "#/$defs/authorizationReceipt"}
      }
    },
    "authorizationReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "token_id",
        "token_digest",
        "payload_digest",
        "issuer_id",
        "key_id",
        "executor_id",
        "device_id",
        "contract_digest",
        "capsule_digest",
        "plan_id",
        "plan_digest",
        "step_id",
        "operator_id",
        "grant",
        "authorized_at_epoch_s",
        "use_number",
        "max_uses"
      ],
      "properties": {
        "token_id": {"type": "string", "minLength": 1},
        "token_digest": {"type": "string", "minLength": 1},
        "payload_digest": {"type": "string", "minLength": 1},
        "issuer_id": {"type": "string", "minLength": 1},
        "key_id": {"type": "string", "minLength": 1},
        "executor_id": {"type": "string", "minLength": 1},
        "device_id": {"type": ["string", "null"]},
        "contract_digest": {"type": "string", "minLength": 1},
        "capsule_digest": {"type": "string", "minLength": 1},
        "plan_id": {"type": "string", "minLength": 1},
        "plan_digest": {"type": "string", "minLength": 1},
        "step_id": {"type": "string", "minLength": 1},
        "operator_id": {"type": "string", "minLength": 1},
        "grant": {"$ref": "#/$defs/capabilityGrant"},
        "authorized_at_epoch_s": {"type": "integer", "minimum": 0},
        "use_number": {"type": "integer", "minimum": 1},
        "max_uses": {"type": "integer", "minimum": 1, "maximum": 1000}
      }
    },
    "capabilityGrant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capability", "resource", "access", "constraints"],
      "properties": {
        "capability": {"type": "string", "minLength": 1},
        "resource": {"type": "string", "minLength": 1},
        "access": {
          "enum": ["read", "write", "execute", "control", "network", "secret_use"]
        },
        "constraints": {"type": "object", "additionalProperties": true}
      }
    },
    "receiptBoundTraceEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "authorization_receipt_digest"],
      "properties": {
        "event": {"$ref": "#/$defs/traceEvent"},
        "authorization_receipt_digest": {"type": ["string", "null"]}
      }
    },
    "traceEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "step_id",
        "sequence",
        "timestamp",
        "operator_id",
        "status",
        "input_digests",
        "output_digests",
        "capability_token_id"
      ],
      "properties": {
        "event_id": {"type": "string", "minLength": 1},
        "step_id": {"type": "string", "minLength": 1},
        "sequence": {"type": "integer", "minimum": 0},
        "timestamp": {"type": "string", "format": "date-time"},
        "operator_id": {"type": "string", "minLength": 1},
        "status": {
          "enum": ["STARTED", "SUCCEEDED", "FAILED", "ROLLED_BACK", "SKIPPED"]
        },
        "input_digests": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "output_digests": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "capability_token_id": {"type": ["string", "null"]}
      }
    }
  }
}
